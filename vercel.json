{
  "version": 2,
  "installCommand": "npm install -g pnpm@10.12.4 && COREPACK_ENABLE_AUTO_PIN=0 pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/stadium-area run build",
  "outputDirectory": "artifacts/stadium-area/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "artifacts/api-server/src/**,lib/db/src/**,lib/api-zod/src/**"
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
