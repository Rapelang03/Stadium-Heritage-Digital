# Copy this to .env for local development.
#
# This project uses an embedded SQLite database — there is nothing external
# to provision, no second service to deploy, and no DATABASE_URL needed.
# The database is just a file on disk, created automatically on first run.

# Path to the SQLite database file. Defaults to ./data/app.db if unset.
# On Render, the Dockerfile already sets this to /app/data/app.db for you.
SQLITE_PATH=./data/app.db

PORT=3000

NODE_ENV=production

# Used to sign session cookies — set this to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string
