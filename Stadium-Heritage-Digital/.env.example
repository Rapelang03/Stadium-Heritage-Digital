# Copy this to .env for local development. On Render, set these as
# environment variables in your service's "Environment" tab instead
# (render.yaml already wires DATABASE_URL and SESSION_SECRET for you).

# Provided automatically by Render's PostgreSQL database if you use the
# included render.yaml (or your own Postgres connection string).
DATABASE_URL=postgres://user:password@host:5432/dbname

# Render injects PORT automatically — you generally don't need to set this
# yourself in the Render dashboard, but it's required for local runs.
PORT=3000

NODE_ENV=production

# Used to sign session cookies — set this to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string
